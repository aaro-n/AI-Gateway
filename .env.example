# ============================================================
# AI Gateway 环境变量（复制为 .env 后修改）
# 优先级: .env > 环境变量 > config.yaml > 默认值
# ============================================================

# ---- PostgreSQL 数据库 ----
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=ai_gateway

# ---- 数据库连接（用于 app 容器连接 PG）----
# AG_DATABASE_TYPE=postgres          # postgres | sqlite（默认 sqlite）
# AG_DATABASE_URL=postgres://user:pass@host:5432/db  # PG 连接 URL（优先级高于下方字段）
# AG_DATABASE_PATH=data.db           # SQLite 数据库文件路径（默认 data.db）
# AG_DATABASE_HOST=postgres          # PG 主机名（docker-compose 用服务名）
# AG_DATABASE_PORT=5432
# AG_DATABASE_USERNAME=postgres
# AG_DATABASE_PASSWORD=postgres
# AG_DATABASE_DBNAME=ai_gateway

# ---- 数据库连接池 ----
# AG_DATABASE_POOL_MAX_OPEN=20       # 最大连接数（SQLite 默认 1）
# AG_DATABASE_POOL_MAX_IDLE=5        # 最大空闲连接数（SQLite 默认 1）
# AG_DATABASE_POOL_MAX_LIFETIME=1h   # 连接最大生命周期
# AG_DATABASE_POOL_MAX_IDLE_TIME=5m  # 空闲连接最大存活时间

# ---- 管理员账号 ----
# AG_ADMIN_USERNAME=admin            # 默认 admin
# AG_ADMIN_PASSWORD=admin            # 默认 admin，生产环境务必修改

# ---- 服务端口 ----
# AG_SERVER_PORT=18080               # 默认 18080
# AG_PPROF_PORT=6060                 # 默认 6060，pprof 性能分析
# AG_SERVER_TRUSTED_PROXIES=10.0.0.0/8,192.168.0.0/16,172.16.0.0/12  # 信任代理 CIDR

# ---- 前端域名 & 时区 & 语言 ----
# AG_SERVER_DOMAIN=http://localhost:18080  # 公网域名（用于密码重置邮件中的链接）
# AG_TIME_ZONE=Asia/Shanghai         # 时区（IANA 名，如 UTC、America/New_York）
# AG_DEFAULT_LANGUAGE=zh             # 默认界面语言（zh / en）

# ---- Session 会话 ----
# AG_SERVER_SESSION_SECRET=          # 留空自动生成随机密钥
# AG_SERVER_SESSION_MAX_AGE=86400    # 默认 86400 秒（24小时）
# AG_SERVER_SESSION_SECURE=false     # 生产环境配合 HTTPS 设为 true
# AG_SERVER_SESSION_HTTP_ONLY=true   # Cookie HttpOnly 标志
# AG_SERVER_SESSION_SAME_SITE=lax    # lax | strict | none

# ---- 日志 ----
# AG_LOG_LEVEL=info                  # debug | info | warn | error
# AG_DEBUG_GIN=false                 # Gin 框架调试日志
# AG_DEBUG_GORM=false                # SQL 查询日志
# AG_DEBUG_PROVIDER=false            # 模型请求/响应调试
# AG_DEBUG_MCP=false                 # MCP 请求/响应调试
# AG_DEBUG_LOG_FILE=                 # 日志文件路径，留空 = stdout

# ---- 模型测试 ----
# AG_TEST_CONCURRENCY=5              # 模型测试并发数

# ---- SMTP 邮件配置（密码重置，可选）----
# AG_SMTP_ENABLED=false              # 是否启用邮件功能
# AG_SMTP_HOST=smtp.example.com      # SMTP 服务器地址
# AG_SMTP_PORT=587                   # 端口（587 STARTTLS / 465 TLS）
# AG_SMTP_USERNAME=your@email.com    # SMTP 认证用户名
# AG_SMTP_PASSWORD=your_password     # SMTP 认证密码/授权码
# AG_SMTP_FROM=AI Gateway <noreply@example.com>  # 发件人地址
# AG_SMTP_USE_TLS=true               # true=TLS直连(465) false=STARTTLS(587)
# AG_SMTP_LOG_RESET_LINK=false       # 将重置链接输出到 stderr（docker logs 可查看）

# ---- Prometheus 监控（可选）----
# AG_MONITOR_PROMETHEUS_ENABLED=false
# AG_MONITOR_PROMETHEUS_METRICS_TOKEN=   # /metrics 端点认证 token

# ---- OpenTelemetry 链路追踪（可选）----
# AG_MONITOR_OTEL_ENABLED=false
# AG_MONITOR_OTEL_ENDPOINT=           # 如 http://localhost:4318
# AG_MONITOR_OTEL_SERVICE_NAME=ai-gateway
